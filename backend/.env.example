# Server
PORT=8080
ENV=development

# MongoDB
MONGO_URI=mongodb://pushupclash:pushupclash@localhost:27017
MONGO_DB=pushupclash

# Clerk (https://dashboard.clerk.com -> API Keys)
CLERK_SECRET_KEY=sk_test_xxx

# Backblaze B2 (S3-compatible). Create an application key + bucket.
# Endpoint looks like: https://s3.us-west-004.backblazeb2.com
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_KEY_ID=xxx
B2_APP_KEY=xxx
B2_BUCKET=pushupclash-media
